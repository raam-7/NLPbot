APP_NAME=NLP Tutor Chatbot API
APP_VERSION=1.0.0
APP_DESCRIPTION=Backend API for AI-Powered NLP Tutor Chatbot

DEBUG=True

HOST=127.0.0.1
PORT=8000

SECRET_KEY=change_this_to_a_long_random_secret_key

DATABASE_URL=postgresql://postgres:password@localhost:5432/nlp_tutor_chatbot

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

FAISS_INDEX_PATH=../vector-db/faiss.index
FAISS_METADATA_PATH=../vector-db/metadata.pkl